{
  "name": "SmartFlight Dev",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "containerEnv": {
    "PLAYWRIGHT_BROWSERS_PATH": "/ms-playwright",
    "PLAYWRIGHT_SKIP_BROWSER_GC": "1"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "postCreateCommand": "sudo mkdir -p /ms-playwright && sudo chown -R vscode:vscode /ms-playwright && cd backend && pip install -r requirements.txt && pip install -e . && python -m playwright install-deps chromium && python -m playwright install chromium && cd ../frontend && npm install",
  "forwardPorts": [8000, 5173],
  "portsAttributes": {
    "8000": { "label": "Backend API" },
    "5173": { "label": "Frontend" }
  },
  "runArgs": ["--env-file", "${localWorkspaceFolder}/backend/.env"]
}
